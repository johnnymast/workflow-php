{
  "name": "johnnymast/logichain",
  "description": "A SOLID-friendly pipeline engine for structuring business logic into clean, composable chains.",
  "type": "library",
  "license": "Apache-2.0",
  "require": {
    "php": ">=8.3"
  },
  "keywords": [
    "php",
    "logic",
    "logic-chain",
    "pipeline",
    "chain",
    "chain-of-responsibility",
    "adapter",
    "business-logic",
    "clean-code",
    "architecture"
  ],
  "minimum-stability": "stable",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "Johnny\\LogicChain\\": "src/",
      "Examples\\": "examples/",
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "pest"
  },
  "authors": [
    {
      "name": "Johnny Mast",
      "email": "mastjohnny@gmail.com"
    }
  ],
  "require-dev": {
    "pestphp/pest": "^3.0",
    "mockery/mockery": "^1.6"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "support": {
    "issues": "https://github.com/johnnymast/logichain/issues",
    "source": "https://github.com/johnnymast/logichain"
  }
}
